{
  "name": "n8n-nodes-moov",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Moov payment platform providing 26 resources and 150+ operations for payment processing, account management, transfers, and financial operations.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-moov.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-moov",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-moov/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "moov",
    "payments",
    "payment-processing",
    "fintech",
    "banking",
    "ach",
    "transfers",
    "wallets",
    "cards",
    "bank-accounts",
    "underwriting",
    "kyc",
    "money-movement",
    "financial-services"
  ],
  "main": "dist/nodes/Moov/Moov.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/MoovApi.credentials.js",
      "dist/credentials/MoovOAuth.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Moov/Moov.node.js",
      "dist/nodes/Moov/MoovTrigger.node.js"
    ]
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.22.0",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  }
}
